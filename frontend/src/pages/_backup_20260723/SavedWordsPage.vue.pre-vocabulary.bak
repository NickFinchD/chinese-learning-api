<template>
  <div>
    <h1 class="mb-8 text-3xl font-bold">
      Saved Words
    </h1>

    <div
      v-if="savedWords.loading"
      class="text-gray-500"
    >
      Loading saved words...
    </div>

    <div
      v-else-if="savedWords.items.length === 0"
      class="text-gray-500"
    >
      You haven't saved any words yet.
    </div>

    <div
      v-else
      class="grid gap-4 md:grid-cols-2 xl:grid-cols-3"
    >
      <div
        v-for="word in savedWords.items"
        :key="word.id"
        class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm"
      >
        <div class="mb-2 flex items-start justify-between">
          <div class="text-2xl font-semibold">
            {{ word.hanzi }}
          </div>

          <span class="inline-flex rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-700">
            HSK {{ word.hsk_level }}
          </span>
        </div>

        <div class="mb-1 text-gray-500">
          {{ word.pinyin }}
        </div>

        <div class="mb-4 text-gray-700">
          {{ word.translation }}
        </div>

        <button
          class="rounded-lg bg-red-50 px-3 py-2 text-sm font-medium text-red-600 transition hover:bg-red-100"
          @click="onRemove(word.id)"
        >
          Remove
        </button>
      </div>
    </div>
  </div>
</template>

<script setup lang="ts">
import { onMounted } from 'vue'

import { useSavedWordsStore } from '@/stores/savedWords'

const savedWords = useSavedWordsStore()

onMounted(() => {
  savedWords.loadSavedWords()
})

function onRemove(wordId: number) {
  savedWords.removeWord(wordId)
}
</script>
